GROQ_API_KEY=your_groq_api_key_here       # Required: console.groq.com
HF_TOKEN=your_huggingface_token_here      # Required: used for EVERY embedding call via HF Inference API
QDRANT_URL=https://your-cluster.qdrant.io  # Required: Qdrant Cloud cluster URL
QDRANT_API_KEY=your_qdrant_api_key_here   # Required: Qdrant Cloud API key
QDRANT_COLLECTION=pdf_chunks
QDRANT_VECTOR_SIZE=384
PDF_REGISTRY_PATH=./pdf_registry.json
NEXT_PUBLIC_API_URL=https://your-service-name.onrender.com